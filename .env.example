# Copy to `.env` and fill in. `.env` is git-ignored (never commit secrets).
# docker compose reads this file automatically.

# Public origin (used for Secure cookies, CORS, the CSRF Origin check, and the
# Google OAuth authorized origin). REQUIRED.
APP_ORIGIN=https://collage.example.com

# Timezone for export-filename date-time stamps (default Europe/Bucharest).
# TZ=Europe/Bucharest

# Branding shown in the app (logo area, login title, browser tab) AND in the OTP
# email (subject + body). Defaults to "Posterly". The SPA brand is baked in at
# build time, so rebuild after changing it:
#   docker compose build collage && docker compose up -d collage
# BRAND_NAME=Posterly
# BRAND_TAGLINE=

# Session signing secret. REQUIRED. Generate a strong one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# --- Google Sign-In ---
# Google Cloud Console -> Credentials -> OAuth client ID (Web application).
# OAuth consent screen: External, *Production*, scopes: openid, email, profile
# (basic/non-sensitive -> no "unverified app" warning, no verification needed).
# Authorized JavaScript origins: your APP_ORIGIN (+ http://localhost:5173 for dev).
GOOGLE_CLIENT_ID=

# --- Email OTP via Resend (https://resend.com) ---
# Verify a sending DOMAIN in Resend (SPF/DKIM DNS) so codes reach all users;
# an unverified domain can only email your own Resend-account address.
RESEND_API_KEY=
RESEND_FROM=Posterly <login@collage.example.com>

# --- Cloudflare Turnstile (anti-bot on the login screen) ---
# Cloudflare dashboard -> Turnstile -> Add site. Add your APP_ORIGIN hostname.
# Both must be set to enable it; leave empty to disable (login works as before).
# The SITE_KEY is public (baked into the SPA at build time); the SECRET is
# server-side only (used for /turnstile/v0/siteverify). After changing the site
# key you MUST rebuild the image (it is a build-time Vite var, like the brand).
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET=

# --- Optional ---
# Force/disable the Secure cookie flag (defaults: true when APP_ORIGIN is https).
# COOKIE_SECURE=1
# Extra allowed origins (comma-separated), if the SPA is also served elsewhere.
# Use only origins you control.
# EXTRA_ORIGINS=
# Include localhost CORS/CSRF origins even when APP_ORIGIN is public (dev only).
# Off by default in production; on automatically when APP_ORIGIN is localhost.
# INCLUDE_DEV_ORIGINS=0
# Extra hostnames accepted by TrustedHostMiddleware (comma-separated). The
# APP_ORIGIN host + localhost/127.0.0.1 are always allowed.
# EXTRA_TRUSTED_HOSTS=
# Session: 7-day sliding window by default (active users roll forward; idle
# sessions expire). Tune the lifetime and how often the cookie is refreshed:
# SESSION_TTL_SECONDS=604800
# SESSION_REFRESH_THRESHOLD_SECONDS=86400

# --- Resource / DoS caps ---
# Upload caps. Keep the reverse-proxy body limit aligned with the aggregate
# request cap. The UI sends roughly 15 MB batches; a large photo is sent alone.
# MAX_FILES_PER_UPLOAD=60
# 40 MB per file.
# MAX_UPLOAD_BYTES=41943040
# 50 MB per multipart request (all files combined, excluding small overhead).
# MAX_UPLOAD_REQUEST_BYTES=52428800
# Reject decompression-bomb uploads by decoded pixel count.
# MAX_IMAGE_MEGAPIXELS=80
# Max rendered output (export). 200 MP covers every paper size incl. 1.4 m
# (195 MP). Lower it to disable the biggest poster sizes; export is also
# rate-limited to 6/min as the primary DoS guard.
# MAX_EXPORT_MEGAPIXELS=200

# --- Retention / disk cleanup (cleanup cron container) ---
# Auto-delete collages untouched for this many days (0 = keep forever; still
# purges expired OTP/temp). Sweep runs every CLEANUP_INTERVAL_SECONDS.
# RETENTION_DAYS=60
# CLEANUP_INTERVAL_SECONDS=86400
# LOCAL DEV/QA ONLY: return OTP codes in the API response (NEVER in production).
# OTP_DEV_EXPOSE=1
# LOCAL DEV ONLY: expose FastAPI docs at /api/docs (off by default).
# ENABLE_DOCS=0
# Domain for the optional Caddy auto-HTTPS proxy profile (`--profile proxy`).
# CADDY_DOMAIN=collage.example.com
# Cloudflare Tunnel token for quick deploy (`--profile cloudflare`). Route the
# tunnel's public hostname to http://collage:8787 and set APP_ORIGIN to its URL.
# TUNNEL_TOKEN=

# --- Reverse proxy options ---
# This app listens on 127.0.0.1:8787 and expects TLS to be terminated upstream.
# IMPORTANT: the proxy caps the per-REQUEST body size; the app uploads photos in
# small batches so this acts as a PER-PHOTO limit. Set it to at least the largest
# single photo you allow (>= MAX_UPLOAD_BYTES, e.g. 40 MB):
#   * Nginx Proxy Manager / Nginx: client_max_body_size 40m;  (default is only 1 MB!)
#   * Cloudflare Free tunnel: ~100 MB hard limit per request (cannot be raised).
#  * Nginx Proxy Manager (NPM): point a Proxy Host at the app and forward to
#    http://collage:8787. If NPM runs in Docker, put this app on NPM's Docker
#    network (or a shared external network) so the hostname `collage` resolves;
#    otherwise forward to the host IP:8787. Set APP_ORIGIN to your NPM domain.
#  * Caddy (bundled, optional): `--profile proxy` + CADDY_DOMAIN (auto-HTTPS).
#  * Cloudflare Tunnel (bundled, optional): `--profile cloudflare` + TUNNEL_TOKEN.

# --- Allow-list (who may log in) ---
# Edited at runtime WITHOUT a restart: ./data/allowed_emails.txt
# One per line; supports exact addresses, *@yourdomain.com, and a lone * (open).
